# ── Secrets — never commit ──────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Runtime data (regenerable / local state) ────────────────────────
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/cache/
data/shutdown_state.json
logs/
reports/*.html
reports/*.pdf

# ── Models (large binaries — track configs, not weights) ────────────
models/*.pt
models/*.pth
models/*.pkl
models/*.h5
models/finbert/
models/checkpoints/
models/patterns/

# ── Quarantined legacy files ────────────────────────────────────────
_quarantine/

# ── OS / editor noise ───────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ML model bundles (regenerable binaries)
models/**/*.joblib
*.joblib
