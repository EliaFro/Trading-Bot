# =============================================================================
# AI Crypto Trading System — environment template
# Copy to .env, fill in real values, then:  chmod 600 .env
# NEVER commit .env. Only this .env.example belongs in version control.
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Trading mode (main.py --mode overrides these) ────────────────────────────
ENABLE_LIVE_TRADING=false
ENABLE_PAPER_TRADING=true

# ── Capital & risk ───────────────────────────────────────────────────────────
INITIAL_CAPITAL=10000.0
MAX_POSITION_SIZE=0.1
RISK_PER_TRADE=0.01
MAX_DRAWDOWN_LIMIT=0.15
DAILY_LOSS_LIMIT=0.03
MAX_CONCURRENT_POSITIONS=5

# ── Binance (spot). Keys must have withdrawals DISABLED for live trading. ────
USE_TESTNET=true
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# ── Sentiment sources (ALL OPTIONAL — system runs keyless via public news) ───
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crypto_sentiment_bot/1.0
TWITTER_BEARER_TOKEN=
CRYPTOCOMPARE_API_KEY=
NEWSAPI_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=./data/trading_system.db
REDIS_URL=redis://localhost:6379

# ── Models ───────────────────────────────────────────────────────────────────
MODEL_PATH=./models
RETRAIN_INTERVAL_HOURS=24
MIN_TRADES_FOR_RETRAIN=100
CONFIDENCE_THRESHOLD=0.6
MIN_SHARPE_RATIO=1.0

# ── Alerting (optional — Telegram is the primary channel) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email channel (requires all SMTP_* values)
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=trading-bot@localhost

# ── Symbols / timeframes (config/trading.yaml is the source of truth) ────────
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAMES=1m,5m,15m,1h
